{
  "ClientSafeList": "",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting": "Information",
      "Microsoft.Extensions.Diagnostics": "Information",
      "Microsoft.Extensions.Diagnostics.HealthChecks": "Information",
      "Artskart3.Api": "Information",
      "Artskart3.Api.HealthChecks": "Information",
      "Startup": "Information"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Auth": {
    "Authority": "",
    "ClientId": "",
    "ClientSecret": ""
  },
  "ConnectionStrings": {
    "ArtskartIndex": ""
  },
  "Database": {
    "AutoMigrate": true
  },
  "KeyVault": {
    "Name": ""
  },
  "Application": {
    "AllowRobotsInProduction": false
  },
  "SlowQueryLogging": {
    "Enabled": true,
    "ThresholdMs": 1000
  },
  "Pagination": {
    "LookaheadMultiplier": 4
  },
  "CsvExport": {
    "BlobStorage": {
      "ConnectionString": "UseDevelopmentStorage=true",
      "ContainerName": "csv-exports"
    },
    "Limits": {
      "SoftRowLimit": 700000,
      "HardRowLimit": 1000000,
      "MaxConcurrentPerUser": 3
    }
  }
}
