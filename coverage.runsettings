<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>

      <!-- Visual Studio built-in coverage collector -->
      <DataCollector friendlyName="Code Coverage" uri="datacollector://Microsoft/CodeCoverage/2.0">
        <Configuration>
          <CodeCoverage>
            <ModulePaths>
              <Exclude>
                <!-- Third-party NuGet packages -->
                <ModulePath>.*\\robotstxtcore\.dll</ModulePath>
                <ModulePath>.*\\duende\..*\.dll</ModulePath>
                <ModulePath>.*\\testcontainers.*\.dll</ModulePath>
                <ModulePath>.*\\docker\.dotnet\.dll</ModulePath>
              </Exclude>
            </ModulePaths>
            <Functions>
              <Exclude>
                <!-- OpenAPI source generator -->
                <Function>^Microsoft\.AspNetCore\.OpenApi\.Generated\..*</Function>
                <!-- System.Runtime.CompilerServices namespace -->
                <Function>^System\.Runtime\.CompilerServices\..*</Function>
                <!-- Compiler-generated async state machines: <MethodName>d__N -->
                <Function>.*&lt;.*&gt;d__\d+.*</Function>
                <!-- Compiler-generated lambda/closure containers: <>c and <>c__DisplayClass -->
                <Function>.*&lt;&gt;c.*</Function>
              </Exclude>
            </Functions>
            <Sources>
              <Exclude>
                <Source>.*\\Migrations\\.*</Source>
              </Exclude>
            </Sources>
          </CodeCoverage>
        </Configuration>
      </DataCollector>

      <!-- Coverlet (XPlat / CI) coverage collector -->
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <ExcludeByFile>**/Migrations/**/*.cs</ExcludeByFile>
          <Exclude>[Artskart3.Api]Microsoft.AspNetCore.OpenApi.Generated*</Exclude>
          <ExcludeByAttribute>CompilerGeneratedAttribute</ExcludeByAttribute>
        </Configuration>
      </DataCollector>

    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
