{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Information"
    }
  },
  "AllowedHosts": "*",
  "KeyVault": {
    "Name": ""
  },
  "ConnectionStrings": {
    "ArtskartIndex": "",
    "ArtskartIndex_Worker": ""
  },
  "Hangfire": {
    "ScheduleDefaults": {
      "DatabaseMaintenance": "0 0 * * *",
      "Harvest": "0 1 * * *",
      "CsvExportPoll": "*/30 * * * * *"
    }
  },
  "CsvExport": {
    "BlobStorage": {
      "ConnectionString": "",
      "ContainerName": "csv-exports"
    },
    "Limits": {
      "SoftRowLimit": 50000,
      "HardRowLimit": 100000,
      "MaxConcurrentPerUser": 3
    },
    "Worker": {
      "BatchSize": 5000,
      "InterBatchDelayMs": 100
    }
  }
}
